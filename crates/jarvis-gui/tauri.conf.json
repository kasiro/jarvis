{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "jarvis-app",
  "version": "0.0.3",
  "identifier": "com.priler.jarvis",
  "build": {
    "beforeDevCommand": "npm run dev --prefix /home/kasiro/Документы/jarvis/frontend",
    "beforeBuildCommand": "npm run build --prefix /home/kasiro/Документы/jarvis/frontend",
    "devUrl": "http://localhost:1420",
    "frontendDist": "/home/kasiro/Документы/jarvis/frontend/dist/client"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "../../resources/icons/32x32.png",
      "../../resources/icons/128x128.png",
      "../../resources/icons/128x128@2x.png",
      "../../resources/icons/icon.icns",
      "../../resources/icons/icon.ico"
    ],
    "targets": ["app"],
    "resources": {
      "../../resources/commands": "resources/commands",
      "../../resources/sound": "resources/sound",
      "../../resources/rustpotter": "resources/rustpotter",
      "../../resources/vosk": "resources/vosk",
      "../../resources/keywords": "resources/keywords"
    }
  }
}
